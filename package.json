{
  "name": "raminrezaei",
  "version": "6.0.2",
  "private": true,
  "scripts": {
    "lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html --chrome-flags=\"--headless\"",
    "check-all": "pnpm run check-format && pnpm run check-lint && pnpm run check-types",
    "performance": "pnpm run build && pnpm run start & sleep 5 && pnpm run lighthouse",
    "check-lint": "eslint \"src/**/*.{ts,tsx,js}\" --max-warnings=0",
    "check-types": "tsc --pretty --noEmit --project ./",
    "dev-https": "next dev --experimental-https",
    "build:analyze": "ANALYZE=true next build --webpack",
    "check-format": "prettier . --check",
    "format": "prettier --write .",
    "dev": "next dev --turbopack",
    "lint": "eslint . --fix",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/bundle-analyzer": "^16.2.4",
    "@next/third-parties": "^16.2.4",
    "@sentry/nextjs": "^10.50.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@vercel/speed-insights": "^2.0.0",
    "animate.css": "^4.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "markdown-to-jsx": "^9.7.16",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "qs": "^6.15.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.74.0",
    "react-toastify": "^11.1.0"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write .",
      "eslint . --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "prettier": "3.8.3",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "browserslist": {
    "production": [
      "chrome >= 109",
      "edge >= 109",
      "firefox >= 102",
      "safari >= 16",
      "ios_saf >= 16"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
